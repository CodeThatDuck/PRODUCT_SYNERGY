  "transformation_rules": {
    "string_to_integer": {
      "description": "Convert string representation to integer",
      "steps": ["trim", "validate_numeric", "convert_to_int"]
    },
    "string_to_decimal": {
      "description": "Convert string to decimal with precision",
      "steps": ["trim", "handle_empty_as_null", "validate_numeric", "convert_to_decimal", "round_to_scale"]
    },
    "trim_string": {
      "description": "Trim whitespace and normalize",
      "steps": ["trim", "handle_empty_as_null", "validate_length"]
    },
    "string_to_timestamp": {
      "description": "Convert string to timestamp",
      "steps": ["trim", "handle_empty_as_null", "parse_timestamp"]
    },
    "pass_through": {
      "description": "Pass value through without transformation",
      "steps": ["no_transformation"]
    }
  },
  "data_quality_rules": {
    "empty_string_handling": "convert_to_null",
    "whitespace_handling": "trim_all",
    "null_representation": null,
    "default_value_strategy": "use_generator_or_skip"
  }
}
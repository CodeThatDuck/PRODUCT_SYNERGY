{
  "tables": {
    "PRODUCTS": {
      "description": "Product metadata table",
      "primary_key": "PRODUCT_ID",
      "columns": {
        "PRODUCT_ID": {
          "oracle_type": "NUMBER(10)",
          "db2_type": "DECIMAL(10,0)",
          "nullable": false,
          "transformation": "string_to_integer",
          "validation": {
            "type": "integer",
            "min": 1,
            "max": 9999999999
          }
        },
        "NAME": {
          "oracle_type": "VARCHAR2(255)",
          "db2_type": "VARCHAR(255)",
          "nullable": false,
          "transformation": "trim_string",
          "validation": {
            "type": "string",
            "max_length": 255,
            "allow_empty": false
          },
          "default_generator": "generate_default_name"
        },
        "PRICE": {
          "oracle_type": "NUMBER(10,2)",
          "db2_type": "DECIMAL(10,2)",
          "nullable": true,
          "transformation": "string_to_decimal",
          "validation": {
            "type": "decimal",
            "precision": 10,
            "scale": 2,
            "min": 0,
            "max": 99999999.99
          }
        }
      }
    },
